# Basics
DirectoryIndex index.php index.html
Options -Indexes
ServerSignature Off

# Security Headers
<IfModule mod_headers.c>
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Compressão GZIP (Alta Performance)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json application/xml application/rss+xml
    AddOutputFilterByType DEFLATE image/svg+xml font/opentype application/x-font-ttf font/otf
    
    # Prevenir bugs em navegadores antigos
    BrowserMatch ^Mozilla/4 gzip-only-text/html
    BrowserMatch ^Mozilla/4\.0[678] no-gzip
    BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
</IfModule>

# Cache de Navegador (Moderno)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    
    # Imagens (1 ano)
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# URL Rewriting (Clean URLs)
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Ignorar a pasta de API para evitar conflitos de rota
    RewriteRule ^api/ - [L]

    # Prevenir acesso direto a includes (Segurança Extra igual ao site oficial)
    RewriteRule ^includes/ - [F,L]

    # Custom Friendly Routes
    # /vagas/123 -> /trabalhe-conosco/vaga.php?id=123
    RewriteRule ^vagas/([a-zA-Z0-9-]+)/?$ trabalhe-conosco/vaga.php?id=$1 [L,QSA]

    # Skip if request maps to existing directory
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Internally map clean URL to .php file (e.g. /about -> /about.php)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.*)$ $1.php [L]
</IfModule>

# Protect Sensitive Files
<FilesMatch "^(secrets|supabase_helper|constants)\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Protect Dot Files (.git, .env, etc) and Markdown/SQL
<FilesMatch "^\.|^.*\.(md|sql)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
